PORT=8787

# 飞书开放平台应用凭证，由客户企业自建应用提供
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 飞书事件订阅校验。未启用可先留空，联调时按客户应用后台填写。
FEISHU_VERIFICATION_TOKEN=

# 飞书邮箱发件人。联调后填写客户提供的公用邮箱或邮箱 ID。
FEISHU_SENDER_MAILBOX_ID=
FEISHU_SENDER_DISPLAY_NAME=BOM释放通知
FEISHU_USER_TOKEN_B64=
FEISHU_SYNC_CHAT_ID=

# 试运行限制。true 时只允许发送到 TEST_RECIPIENTS 中的邮箱。
SAFE_TEST_MODE=true
EMAIL_DRY_RUN=true
INCLUDE_FACTORY_RECIPIENTS=false
FIXED_RECIPIENTS=
TEST_RECIPIENTS=

# Optional polling fallback for Bitable records.
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=
BITABLE_SOURCES=
BITABLE_SKIP_EXISTING_ON_START=false
